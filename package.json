const express = require("express");
const cors = require("cors");
const axios = require("axios");

const app = express();
app.use(cors());
app.use(express.json());

// 🔑 VOICE AI
const API_KEY = "ELEVENLABS_KEY";
const VOICE_ID = "21m00Tcm4TlvDq8ikWAM";

app.post("/create-song", async (req, res) => {

    const { lyrics, style } = req.body;

    if (!lyrics) {
        return res.status(400).json({ error: "Şarkı sözü yok" });
    }

    try {

        // 🎤 1. VOICE (AI SES)
        const voiceRes = await axios.post(
            `https://api.elevenlabs.io/v1/text-to-speech/${VOICE_ID}`,
            {
                text: lyrics,
                model_id: "eleven_multilingual_v2",
                voice_settings: {
                    stability: 0.5,
                    similarity_boost: 0.8
                }
            },
            {
                headers: {
                    "xi-api-key": API_KEY,
                    "Content-Type": "application/json",
                    "Accept": "audio/mpeg"
                },
                responseType: "arraybuffer"
            }
        );

        const voiceAudio = Buffer.from(voiceRes.data).toString("base64");

        // 🎵 2. BEAT (şimdilik demo)
        const beat = "https://www.soundhelix.com/examples/mp3/SoundHelix-Song-1.mp3";

        // 🔥 3. FINAL OUTPUT
        res.json({
            status: "ok",
            style: style || "default",
            voice: "generated",
            voice_audio: "data:audio/mpeg;base64," + voiceAudio,
            beat: beat
        });

    } catch (err) {
        console.log(err.message);
        res.status(500).json({ error: "AI üretim hatası" });
    }
});

app.listen(3000, () => {
    console.log("🔥 SK PRO MUSIC SYSTEM RUNNING");
});
